{
  "name": "vaultaccess",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "start": "node server/production-server.mjs",
    "lint": "node --check src/hrCore.js && node --check server/production-server.mjs && node --check tests/hrCore.test.mjs",
    "test": "node --test tests/*.test.mjs",
    "test:e2e": "node --test tests/e2e.smoke.test.mjs",
    "typecheck": "node --check src/hrCore.js && node --check tests/hrCore.test.mjs && node --check server/production-server.mjs",
    "supabase:migration:print": "node -e \"console.log(require('fs').readFileSync('supabase/migrations/001_hrms_app_state.sql','utf8'))\"",
    "docker:build": "docker build -t eagle-rcm-hrms:latest ."
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "bcryptjs": "latest",
    "otpauth": "latest",
    "qrcode": "latest",
    "vite": "latest",
    "xlsx": "latest",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {}
}
